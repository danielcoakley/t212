# Copy to .env.local for local development. Never commit real secrets.
ISA_ENVIRONMENT=local
ISA_BIND_HOST=127.0.0.1
ISA_BIND_PORT=8002
PORTFOLIO_API_HOST=127.0.0.1
PORTFOLIO_API_PORT=8002
ISA_RUNTIME_MODE=preview
ISA_LIVE_ARMED=false
ISA_KILL_SWITCH_ENABLED=false
LIVE_TRADING_ENABLED=false
ISA_TIMEZONE=Europe/London
ISA_OPERATIONAL_DB_DSN=sqlite:///./artifacts/isa_system.sqlite3
ISA_DATA_LAKE_PATH=./data_lake
ISA_ARTIFACTS_PATH=./artifacts
ISA_OPENBB_VENDOR_PATH=./vendor/OpenBB
ISA_OPENBB_LOCK_PATH=./configs/openbb.lock.json
ISA_OPENBB_DEFAULT_PROVIDER=yfinance
ISA_OPENBB_SCREENER_PROVIDER=yfinance
ISA_OPENBB_SCREENER_COUNTRY=us
# ISA_OPENBB_SCREENER_EXCHANGE=
ISA_OPENBB_SCREENER_MARKET_CAP_MIN=1000000000
ISA_OPENBB_SCREENER_VOLUME_MIN=100000
ISA_OPENBB_BACKEND=odp_rest
ISA_OPENBB_ODP_API_BASE_URL=http://127.0.0.1:6900
# ISA_OPENBB_ODP_API_USERNAME=
# ISA_OPENBB_ODP_API_PASSWORD=
OPENBB_API_URL=http://127.0.0.1:6900
OPENBB_MCP_URL=http://127.0.0.1:8001

# Trading 212 Public API. Leave blank for offline smoke tests and synthetic demos.
# Configure for read-only account, position, order, and broker-universe context.
# Use demo first. Set live only when intentionally reading live account context.
TRADING212_API_KEY=
TRADING212_API_SECRET=
TRADING212_ENVIRONMENT=demo
TRADING212_MODE=demo

# Convenience data providers. Leave blank unless used by a pilot.
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
FRED_API_KEY=
COMPANIES_HOUSE_API_KEY=

# SEC asks automated clients to identify themselves.
SEC_USER_AGENT=isa-system-dev example@example.com

# Optional sentiment overlays, disabled by default.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=

# Optional AI research and portfolio-analysis workflows.
# Leave OPENAI_API_KEY blank to keep model-backed research unavailable and conservative.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_HEALTH_CHECK_MODEL=gpt-5.5
OPENAI_HEALTH_CHECK_REASONING_EFFORT=medium
OPENAI_HEALTH_CHECK_DETAILED_REASONING_EFFORT=high
OPENAI_STOCK_VALUATION_MODEL=gpt-5.5
OPENAI_STOCK_VALUATION_REASONING_EFFORT=high
OPENAI_STOCK_VALUATION_MAX_REASONING_EFFORT=xhigh
OPENAI_SOURCE_RESEARCH_MODEL=o3-deep-research
OPENAI_ENABLE_O3_SOURCE_RESEARCH=false
OPENAI_HEALTH_CHECK_MAX_OUTPUT_TOKENS=6000
OPENAI_STOCK_VALUATION_MAX_OUTPUT_TOKENS=14000
OPENAI_SOURCE_RESEARCH_MAX_OUTPUT_TOKENS=20000
OPENAI_DEEP_VALUATION_MAX_CONCURRENCY=1
OPENAI_DEEP_RESEARCH_SELECTED_STOCK_LIMIT=5
